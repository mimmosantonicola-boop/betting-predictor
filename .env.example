# ─────────────────────────────────────────────
#  Betting Predictor — Environment Variables
# ─────────────────────────────────────────────

# Groq API (free at https://console.groq.com)
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile

# Football data (free at https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# API-Football — World Cup & WCQ fixtures (free 100 req/day at https://dashboard.api-football.com/register)
API_FOOTBALL_KEY=your_api_football_key_here

# Local memory database (no changes needed)
LOCAL_ZEP_DB_PATH=./data/local_memory.db

# MiroFish backend URL (no changes needed)
MIROFISH_API_URL=http://localhost:5001
